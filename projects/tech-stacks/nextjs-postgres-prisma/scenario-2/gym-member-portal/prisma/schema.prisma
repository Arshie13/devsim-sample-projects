generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id        String   @id @default(uuid())
  email          String   @unique
  first_name     String
  last_name      String
  phone          String?
  email_verified Boolean  @default(false)
  status         String   @default("active")
  created_at     DateTime @default(now())

  memberships Membership[]
  bookings    Booking[]
  attendances Attendance[]

  @@map("users")
}

model Membership {
  id         Int      @id @default(autoincrement())
  user_id    String
  type       String
  status     String
  start_date DateTime
  end_date   DateTime

  user User @relation(fields: [user_id], references: [user_id])

  @@map("memberships")
}

model Class {
  id         Int    @id @default(autoincrement())
  name       String
  schedule   String
  instructor String
  capacity   Int

  bookings    Booking[]
  attendances Attendance[]

  @@map("classes")
}

model Booking {
  id        Int      @id @default(autoincrement())
  user_id   String
  class_id  Int
  booked_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [user_id])
  class Class @relation(fields: [class_id], references: [id])

  @@map("bookings")
}

model Attendance {
  id          Int      @id @default(autoincrement())
  user_id     String
  class_id    Int
  attended_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [user_id])
  class Class @relation(fields: [class_id], references: [id])

  @@map("attendances")
}
