{
  "packageManager": "pnpm@10.32.1",
  "name": "to-do-list-tutorial",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal MERN tutorial project: one-page to-do list",
  "scripts": {
    "dev": "concurrently \"pnpm:dev:server\" \"pnpm:dev:client\"",
    "dev:server": "cd server && pnpm run dev",
    "dev:client": "cd client && pnpm run dev",
    "build": "pnpm run build:server && pnpm run build:client",
    "build:server": "cd server && pnpm run build",
    "build:client": "cd client && pnpm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
