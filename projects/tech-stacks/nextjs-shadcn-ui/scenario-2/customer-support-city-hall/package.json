{
  "name": "customer-support-city-hall",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:level": "vitest run --reporter=verbose --testPathPattern",
    "test:task:l1:t1": "vitest run tests/level-1/task-1/environment-setup.test.tsx",
    "test:task:l1:t2": "vitest run tests/level-1/task-2/ui-text-updates.test.tsx",
    "test:task:l2:t1": "vitest run tests/level-2/task-1/intent-engine.test.tsx",
    "test:task:l2:t2": "vitest run tests/level-2/task-2/quick-replies.test.tsx",
    "test:task:l3:t1": "vitest run tests/level-3/task-1/priority-sorting.test.tsx",
    "test:task:l3:t2": "vitest run tests/level-3/task-2/sla-indicator.test.tsx",
    "test:task:l4:t1": "vitest run tests/level-4/task-1/queue-estimator.test.tsx",
    "test:task:l4:t2": "vitest run tests/level-4/task-2/keyboard-shortcuts.test.tsx",
    "test:task:l5:t1": "vitest run tests/level-5/task-1/dashboard-bug-hunt.test.tsx",
    "test:task:l5:t2": "vitest run tests/level-5/task-2/transcript-docs.test.tsx",
    "test:tasks": "pnpm run test:task:l1:t1 && pnpm run test:task:l1:t2 && pnpm run test:task:l2:t1 && pnpm run test:task:l2:t2 && pnpm run test:task:l3:t1 && pnpm run test:task:l3:t2 && pnpm run test:task:l4:t1 && pnpm run test:task:l4:t2 && pnpm run test:task:l5:t1 && pnpm run test:task:l5:t2"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.2",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
