{
  "name": "student-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:level": "vitest run --reporter=verbose --testPathPattern",
    "test:task:l1:t1": "vitest run tests/level-1/task-1/setup.test.ts",
    "test:task:l1:t2": "vitest run tests/level-1/task-2/branding.test.ts",
    "test:task:l2:t1": "vitest run tests/level-2/task-1/info-tooltip.test.tsx",
    "test:task:l2:t2": "vitest run tests/level-2/task-2/semester-group.test.tsx",
    "test:task:l3:t1": "vitest run tests/level-3/task-1/per-semester-gpa.test.tsx",
    "test:task:l3:t2": "vitest run tests/level-3/task-2/progress-component.test.tsx",
    "test:task:l4:t1": "vitest run tests/level-4/task-1/course-detail-route.test.tsx",
    "test:task:l4:t2": "vitest run tests/level-4/task-2/request-document-modal.test.tsx",
    "test:task:l5:t1": "vitest run tests/level-5/task-1/standing-aggregates.test.tsx",
    "test:task:l5:t2": "vitest run tests/level-5/task-2/a11y-sweep.test.tsx",
    "test:tasks": "pnpm run test:task:l1:t1 && pnpm run test:task:l1:t2 && pnpm run test:task:l2:t1 && pnpm run test:task:l2:t2 && pnpm run test:task:l3:t1 && pnpm run test:task:l3:t2 && pnpm run test:task:l4:t1 && pnpm run test:task:l4:t2 && pnpm run test:task:l5:t1 && pnpm run test:task:l5:t2"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
