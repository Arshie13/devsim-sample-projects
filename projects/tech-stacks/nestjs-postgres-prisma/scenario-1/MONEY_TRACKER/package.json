{
  "name": "flexi-spend-api",
  "version": "1.0.0",
  "description": "FlexiSpend Personal Finance Management API - NestJS + PostgreSQL + Prisma",
  "author": "IPPO Software Solutions",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:tasks:l1": "vitest run tests/server/level-1",
    "test:tasks:l1:t1": "vitest run tests/server/level-1/task-1",
    "test:tasks:l1:t2": "vitest run tests/server/level-1/task-2",
    "test:tasks:l2": "vitest run tests/server/level-2",
    "test:tasks:l2:t1": "vitest run tests/server/level-2/task-1",
    "test:tasks:l2:t2": "vitest run tests/server/level-2/task-2",
    "test:tasks:l3": "vitest run tests/server/level-3",
    "test:tasks:l3:t1": "vitest run tests/server/level-3/task-1",
    "test:tasks:l3:t2": "vitest run tests/server/level-3/task-2",
    "test:tasks:l4": "vitest run tests/server/level-4",
    "test:tasks:l4:t1": "vitest run tests/server/level-4/task-1",
    "test:tasks:l4:t2": "vitest run tests/server/level-4/task-2",
    "test:tasks:l5": "vitest run tests/server/level-5",
    "test:tasks:l5:t1": "vitest run tests/server/level-5/task-1",
    "test:tasks:l5:t2": "vitest run tests/server/level-5/task-2",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "^5.8.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@vitest/coverage-v8": "^2.0.0",
    "vitest": "^2.0.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/passport-jwt": "^4.0.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "prisma": "^5.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
