{
  "packageManager": "pnpm@10.32.1",
  "name": "library-management",
  "version": "1.0.0",
  "private": true,
  "description": "Library Management System - Full Stack Test Runner",
  "scripts": {
    "test": "concurrently \"pnpm:test:server\" \"pnpm:test:client\"",
    "test:server": "cd server && pnpm run test:run",
    "test:client": "cd client && pnpm run test:run",
    "test:server:coverage": "cd server && pnpm run test:coverage",
    "test:client:coverage": "cd client && pnpm run test:coverage",
    "test:all": "concurrently \"pnpm:test:server:coverage\" \"pnpm:test:client:coverage\"",
    "test:level": "pnpm run test:level:server && pnpm run test:level:client",
    "test:level:server": "cd server && pnpm run test:level",
    "test:level:client": "cd client && pnpm run test:level",
    "test:task:client:l1:t1": "cd client && pnpm run test:task:l1:t1",
    "test:task:client:l1:t2": "cd client && pnpm run test:task:l1:t2",
    "test:task:client:l2:t1": "cd client && pnpm run test:task:l2:t1",
    "test:task:client:l2:t2": "cd client && pnpm run test:task:l2:t2",
    "test:task:client:l4:t1": "cd client && pnpm run test:task:l4:t1",
    "test:task:client:l4:t2": "cd client && pnpm run test:task:l4:t2",
    "test:task:server:l3:t1": "cd server && pnpm run test:task:l3:t1",
    "test:task:server:l3:t2": "cd server && pnpm run test:task:l3:t2",
    "test:task:server:l4:t1": "cd server && pnpm run test:task:l4:t1",
    "test:task:server:l4:t2": "cd server && pnpm run test:task:l4:t2",
    "test:task:server:l5:t1": "cd server && pnpm run test:task:l5:t1",
    "test:task:server:l5:t2": "cd server && pnpm run test:task:l5:t2",
    "test:task:l4:t1": "concurrently \"pnpm:test:task:client:l4:t1\" \"pnpm:test:task:server:l4:t1\"",
    "test:task:l4:t2": "concurrently \"pnpm:test:task:client:l4:t2\" \"pnpm:test:task:server:l4:t2\"",
    "test:tasks:l1": "pnpm run test:task:client:l1:t2 && pnpm run test:task:client:l1:t1",
    "test:tasks:l2": "concurrently \"pnpm:test:task:client:l2:t1\" \"pnpm:test:task:client:l2:t2\"",
    "test:tasks:l3": "pnpm run test:task:server:l3:t1 && pnpm run test:task:server:l3:t2",
    "test:tasks:l4": "concurrently \"pnpm:test:task:client:l4:t1\" \"pnpm:test:task:client:l4:t2\" && pnpm run test:task:server:l4:t1 && pnpm run test:task:server:l4:t2",
    "test:tasks:l5": "pnpm run test:task:server:l5:t1 && pnpm run test:task:server:l5:t2",
    "test:ui": "concurrently \"pnpm:test:server:ui\" \"pnpm:test:client:ui\"",
    "test:tasks:server": "concurrently \"pnpm:test:task:server:l3:t1\" \"pnpm:test:task:server:l4:t2\" \"pnpm:test:task:server:l5:t1\" \"pnpm:test:task:server:l5:t2\"",
    "test:tasks:all": "concurrently \"pnpm:test:task:client:l1:t1\" \"pnpm:test:task:client:l1:t2\" \"pnpm:test:task:client:l2:t1\" \"pnpm:test:task:client:l2:t2\" \"pnpm:test:task:server:l3:t1\" \"pnpm:test:task:server:l4:t2\" \"pnpm:test:task:server:l5:t1\" \"pnpm:test:task:server:l5:t2\"",
    "test:server:ui": "cd server && pnpm run test:ui",
    "test:client:ui": "cd client && pnpm run test:ui",
    "dev": "concurrently \"pnpm:dev:server\" \"pnpm:dev:client\"",
    "dev:server": "cd server && pnpm run dev",
    "dev:client": "cd client && pnpm run dev"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^8.2.2"
  }
}
