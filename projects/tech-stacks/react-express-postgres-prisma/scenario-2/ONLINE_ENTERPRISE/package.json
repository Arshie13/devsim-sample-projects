{
  "name": "urbanpottery-online-enterprise",
  "version": "1.0.0",
  "private": true,
  "description": "UrbanPottery Online Enterprise — DevSim PERN challenge",
  "scripts": {
    "dev": "concurrently \"cd server && npm run dev\" \"cd client && npm run dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:tasks:l1": "vitest run tests/client/level-1",
    "test:tasks:l2": "vitest run tests/client/level-2",
    "test:tasks:l3": "vitest run tests/server/level-3",
    "test:tasks:l4": "vitest run tests/client/level-4 tests/server/level-4",
    "test:tasks:l5": "vitest run tests/server/level-5",
    "test:task:client:l1:t1": "vitest run tests/client/level-1/task-1",
    "test:task:client:l1:t2": "vitest run tests/client/level-1/task-2",
    "test:task:client:l2:t1": "vitest run tests/client/level-2/task-1",
    "test:task:client:l2:t2": "vitest run tests/client/level-2/task-2",
    "test:task:server:l3:t1": "vitest run tests/server/level-3/task-1",
    "test:task:server:l3:t2": "vitest run tests/server/level-3/task-2",
    "test:task:client:l4:t1": "vitest run tests/client/level-4/task-1",
    "test:task:client:l4:t2": "vitest run tests/client/level-4/task-2",
    "test:task:server:l4:t1": "vitest run tests/server/level-4/task-1",
    "test:task:server:l4:t2": "vitest run tests/server/level-4/task-2",
    "test:task:server:l5:t1": "vitest run tests/server/level-5/task-1",
    "test:task:server:l5:t2": "vitest run tests/server/level-5/task-2",
    "test:task:l4:t1": "vitest run tests/client/level-4/task-1 tests/server/level-4/task-1",
    "test:task:l4:t2": "vitest run tests/client/level-4/task-2 tests/server/level-4/task-2",
    "test:level": "npm run test:level:server && npm run test:level:client",
    "test:level:server": "cd server && npm run test:level",
    "test:level:client": "cd client && npm run test:level",
    "test:server": "cd server && npm run test:run",
    "test:client": "cd client && npm run test:run",
    "test:server:coverage": "cd server && npm run test:coverage",
    "test:client:coverage": "cd client && npm run test:coverage",
    "test:all": "concurrently \"npm:test:server:coverage\" \"npm:test:client:coverage\"",
    "test:ui": "concurrently \"npm:test:server:ui\" \"npm:test:client:ui\"",
    "test:server:ui": "cd server && npm run test:ui",
    "test:client:ui": "cd client && npm run test:ui",
    "test:tasks:server": "concurrently \"npm:test:task:server:l3:t1\" \"npm:test:task:server:l4:t2\" \"npm:test:task:server:l5:t1\" \"npm:test:task:server:l5:t2\"",
    "test:tasks:all": "concurrently \"npm:test:task:client:l1:t1\" \"npm:test:task:client:l1:t2\" \"npm:test:task:client:l2:t1\" \"npm:test:task:client:l2:t2\" \"npm:test:task:server:l3:t1\" \"npm:test:task:server:l4:t2\" \"npm:test:task:server:l5:t1\" \"npm:test:task:server:l5:t2\""
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
